# App
NODE_ENV=development
PORT=3000

# Telegram Bot
BOT_TOKEN=your_bot_token_here
BOT_WEBHOOK_URL=https://yourdomain.com
BOT_WEBHOOK_SECRET=your_webhook_secret

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/telegram_bot?schema=public"

# Redis (optional, for sessions)
REDIS_URL=redis://localhost:6379
